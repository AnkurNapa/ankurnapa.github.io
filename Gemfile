source "https://rubygems.org"

# The github-pages gem pins the exact Jekyll + plugin versions that
# GitHub Pages builds with, so local previews match production.
# It already bundles jekyll-seo-tag, jekyll-sitemap, and jekyll-feed.
gem "github-pages", group: :jekyll_plugins

# Local preview server on modern Ruby (3.0+).
gem "webrick", "~> 1.8"
